{
  "name": "employee-management-system",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm --prefix frontend run build && cp -r frontend/dist dist || xcopy /E /I /Y frontend\\dist dist",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "lint": "npm --prefix frontend run lint"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.1"
  }
}
